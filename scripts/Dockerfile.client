FROM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    libjson-c-dev \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY build/detector_client /app/detector_client
COPY test.jpg /app/test.jpg

ENTRYPOINT ["/app/detector_client"]
CMD ["--server", "detector-server", "--port", "9090", "--image", "/app/test.jpg"]
